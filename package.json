{
    "name": "sxpanel",
    "version": "0.6.0-Beta",
    "description": "sxPanel - A Replacement for txAdmin built on its source code.",
    "module": "./core/index.js",
    "type": "module",
    "workspaces": [
        "core",
        "nui",
        "panel",
        "shared"
    ],
    "scripts": {
        "build": "rimraf monitor tmp_core_tsc && npm run build -w nui && npm run build -w panel && npm run build -w core && npm run license:distfile",
        "prepare": "husky",
        "test:scripts": "vitest run scripts/build/utils.test.ts",
        "test": "npm run test:scripts && npm run test --workspaces && node scripts/list-dependencies.js core && node scripts/list-dependencies.js panel && node scripts/list-dependencies.js nui && node scripts/list-dependencies.js shared",
        "typecheck": "npm run typecheck --workspaces",
        "locale:rebase": "node scripts/locale-utils.js rebase",
        "locale:check": "node scripts/locale-utils.js check --color",
        "license:report": "rimraf .reports/license && mkdir \".reports/license\" && npm run license:report --workspaces",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "license:list": "node scripts/list-licenses.js",
        "license:distfile": "generate-license-file --ci --no-spinner --overwrite --config generate-license-file.config.json --input package.json --output monitor/THIRD-PARTY-LICENSES.txt",
        "openapi:generate": "npx tsx scripts/generate-openapi.ts",
        "package:zip": "node scripts/package-monitor.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Snipzil/sxpanel.git"
    },
    "author": "snipz",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Snipzil/sxpanel/issues"
    },
    "homepage": "https://sxpanel.org/",
    "dependencies": {
        "chalk": "^5.6.2",
        "dequal": "^2.0.3",
        "discord.js": "14.26.4",
        "humanize-duration": "^3.33.2",
        "jsonrepair": "^3.14.0",
        "lodash-es": "^4.18.1",
        "monaco-editor": "0.53.0",
        "nanoid": "5.1.9",
        "semver": "^7.7.4",
        "vite": "8.1.0"
    },
    "overrides": {
        "monaco-editor": "0.53.0",
        "undici": "6.27.0",
        "ws": "8.21.0"
    },
    "devDependencies": {
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@commitlint/cli": "^20.5.2",
        "@commitlint/config-conventional": "^20.5.0",
        "@johnnymorganz/stylua-bin": "^2.4.0",
        "@types/humanize-duration": "^3.27.4",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "archiver": "^7.0.1",
        "chokidar": "^5.0.0",
        "esbuild": "^0.28.1",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "generate-license-file": "^4.1.1",
        "husky": "^9.1.7",
        "node-stream-zip": "^1.15.0",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.7.3",
        "rimraf": "^6.1.3",
        "rollup-plugin-visualizer": "7.0.1",
        "typescript": "^6.0.3",
        "utility-types": "^3.11.0",
        "vitest": "^4.1.5"
    }
}
